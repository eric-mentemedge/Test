<#
.SYNOPSIS
    EternalBlue (MS17-010 / CVE-2017-0144) Patch Checker
    - Uses ONLY the "OS Version" line from systeminfo (no OS Name/Caption)
    - Works on ALL Windows versions from XP onward (embedded/IoT/POSReady/etc.)
    - Checks hotfixes + build number against full official Microsoft KB/roll-up list
#>

# === Show raw systeminfo output exactly as requested ===
Write-Host "=== RAW SYSTEMINFO OUTPUT (for verification) ===" -ForegroundColor Cyan
$sysinfo = systeminfo | Out-String
$sysinfo | Select-String "OS Name|OS Version|OS Build|System Type|Hotfix" | Out-Host

# === Parse ONLY the OS Version line from systeminfo ===
$versionLine = $sysinfo | Select-String "OS Version:" | Select-Object -First 1
if (-not $versionLine) {
    Write-Host "ERROR: Could not find 'OS Version' in systeminfo output." -ForegroundColor Red
    exit 1
}

$versionText = $versionLine.Line.Trim()
Write-Host "`nParsed OS Version line (from systeminfo): $versionText" -ForegroundColor Yellow

# Extract major.minor.build (handles formats like "10.0.19045", "6.1.7601", "5.1.2600 Service Pack 3 Build 2600", etc.)
$versionRegex = [regex]::Match($versionText, '(\d+\.\d+\.?\d*)')
$osVersionStr = $versionRegex.Groups[1].Value
$versionParts = $osVersionStr -split '\.'

$major = [int]$versionParts[0]
$minor = if ($versionParts.Count -gt 1) { [int]$versionParts[1] } else { 0 }
$build  = if ($versionParts.Count -gt 2) { [int]$versionParts[2] } else { 0 }

# Some systeminfo lines have "Build XXXX" at the end – catch that too
$buildMatch = [regex]::Match($versionText, 'Build\s+(\d+)')
if ($buildMatch.Success) {
    $build = [int]$buildMatch.Groups[1].Value
}

Write-Host "Parsed from systeminfo -> Major: $major | Minor: $minor | Build: $build" -ForegroundColor Cyan

# === Get installed hotfixes (strip "KB" prefix) ===
$hotfixes = (Get-HotFix | Select-Object -ExpandProperty HotFixID) -replace '^KB',''

# === Complete official KB list (initial patches + EVERY monthly roll-up that included MS17-010) ===
$patchedKBs = @()

if ($major -eq 5) {
    # Windows XP (5.1) / Server 2003 (5.2) — official out-of-band patch
    $patchedKBs = @('4012598')
}
elseif ($major -eq 6 -and $minor -eq 0) {
    # Windows Vista / Server 2008
    $patchedKBs = @('4012598')
}
elseif ($major -eq 6 -and $minor -eq 1) {
    # Windows 7 / Server 2008 R2 + all embedded/POSReady 7 variants
    $patchedKBs = @('4012212','4012215','4012218','4015549','4015552','4019263','4019264','4019265','4022722','4022168')
}
elseif ($major -eq 6 -and $minor -eq 2) {
    # Windows 8 / Server 2012
    $patchedKBs = @('4012214','4012217','4012220','4015551','4015554','4019214','4019216','4019218','4022724')
}
elseif ($major -eq 6 -and $minor -eq 3) {
    # Windows 8.1 / Server 2012 R2
    $patchedKBs = @('4012213','4012216','4012219','4015550','4015553','4019213','4019215','4019217','4022720')
}
elseif ($major -eq 10) {
    # Windows 10 / Server 2016 / 2019 / 2022 / all IoT / Windows 11 (version always reported as 10.0)
    $patchedKBs = @('4012606','4016637','4015221','4019474',   # 1507
                    '4013198','4016636','4015219','4019473',   # 1511
                    '4013429','4016635','4015217','4019472')   # 1607 / Server 2016
}

# Check if any patching KB is installed
$isPatchedByKB = $false
foreach ($kb in $patchedKBs) {
    if ($hotfixes -contains $kb) {
        $isPatchedByKB = $true
        Write-Host "Found patching hotfix KB$kb" -ForegroundColor Green
        break
    }
}

# Build-based check for Windows 10+ (cumulative updates include the fix)
$isPatchedByBuild = $false
if ($major -eq 10 -and $build -ge 10240) {
    $isPatchedByBuild = $true
}

# === Final verdict ===
Write-Host "`n=== ETERNALBLUE (MS17-010) PATCH STATUS ===" -ForegroundColor Cyan
if ($isPatchedByKB -or $isPatchedByBuild) {
    Write-Host "PATCHED – System is protected against EternalBlue." -ForegroundColor Green
    if ($isPatchedByBuild) {
        Write-Host "   (Detected via build number $build – all later cumulative updates include the patch)" -ForegroundColor Green
    }
}
else {
    Write-Host "VULNERABLE or UNKNOWN – No matching KB or sufficient build number found." -ForegroundColor Red
    Write-Host "Recommendation: Install the latest available security updates for this version." -ForegroundColor Yellow
}

Write-Host "`nThis check used ONLY the OS Version + Build from systeminfo + installed hotfixes." -ForegroundColor Gray
Write-Host "Additional hardening (recommended):" -ForegroundColor Cyan
Write-Host "  • Disable SMBv1: Disable-WindowsOptionalFeature -Online -FeatureName SMB1Protocol" -ForegroundColor Gray
Write-Host "  • Block TCP 445 at network level if possible." -ForegroundColor Gray
